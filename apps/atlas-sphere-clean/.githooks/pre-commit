#!/usr/bin/env bash
# Template Git hook that runs repository-managed checks.
# Copy to .git/hooks/pre-commit or run `scripts/install-git-hooks.sh` to install.
set -euo pipefail

# Run the repository pre-commit detectors (Python hook + shell detector)
if command -v pre-commit >/dev/null 2>&1; then
  pre-commit run --hook || exit 1
fi

# Run the shell-based test tamper detector
scripts/pre-commit-test-tamper.sh || exit 1

# ☢️ YOLO FINISHER v5.0 — Hard Gate Checks
if [ -x ".clinerules/hooks/finisher-pre-commit.sh" ]; then
  .clinerules/hooks/finisher-pre-commit.sh || exit 1
fi
#!/usr/bin/env bash
set -euo pipefail
python3 scripts/enforce_x3_rules.py
exit 0