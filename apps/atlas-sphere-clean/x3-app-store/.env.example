# X3 App Store Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017/x3-app-store

# GitHub API
GITHUB_TOKEN=your_github_token_here

# Port Configuration
PORT=3000
FRONTEND_PORT=3001

# Exchange APIs
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Development
NODE_ENV=development
DEBUG=x3-app-store:*