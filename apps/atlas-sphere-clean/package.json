  "scripts": {
    "start": "node llm-service/router.js",
    "start:dev": "node llm-service/router.js --config ./llm-config.json",
    "test": "cypress run",
    "test:open": "cypress open",
    "test:polkawallet": "npm test --workspace packages/polkawallet-plugin",
    "test:bridge": "npm test --workspace packages/polkawallet-bridge-adapter",
    "test:ts-sdk": "npm test --workspace packages/ts-sdk",
    "test:all-packages": "npm test --workspaces --if-present",
    "build:polkawallet": "npm run build --workspace packages/polkawallet-plugin",
    "build:bridge": "npm run build --workspace packages/polkawallet-bridge-adapter",
    "build:all-packages": "npm run build --workspaces --if-present",
    "bmad:install": "npm --prefix crates/vibe-bmad run install-bmad",
    "bmad:status": "npm --prefix crates/vibe-bmad run status",
    "bmad:ci-install": "npm --prefix crates/vibe-bmad run ci-install",
    "llm:router": "node llm-service/router.js",
    "llm:examples": "node llm-service/examples.js",
    "llm:verify": "bash verify-llm-integration.sh",
    "finisher:nuclear": "scripts/finisher_daemon.py",
    "finisher:score": "make finish-score",
    "finisher:chaos": "make finish-chaos",
    "finisher:audit": "make finish-audit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:check:remark-links": "remark . --quiet --frail --use remark-validate-links --ignore-path .remarkignore",
    "docs:check:mdrefs": "mdrefcheck . --exclude tools/get-shit-done --exclude idea-IU-253.32098.37 --exclude x3fronend/PRPs/templates --exclude scripts/p4_utils --exclude implementation_plan.md --exclude masterchecklist.md --exclude docs/runbooks/getting-started/100GUIDE.md --exclude docs/testnet-config --exclude docs/reports --exclude docs/openspec --exclude docs/planning-artifacts --exclude docs/master/releases --exclude docs/master/implementation --exclude docs/runbooks/deployment",
    "docs:check:python-examples": "python scripts/check_markdown_python_examples.py",
    "docs:check:runmd": "bash scripts/check_runmd_examples.sh",
    "docs:check": "npm run docs:check:remark-links && npm run docs:check:mdrefs && npm run docs:check:python-examples && npm run docs:check:runmd"
  },
  "name": "x3-chain-master",
  "version": "1.0.0",
